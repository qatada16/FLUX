{
  "expo": {
    "name": "Flux",
    "slug": "flux-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/FLUX.png",
    "userInterfaceStyle": "dark",
    "scheme": "flux",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B0E14",
        "foregroundImage": "./assets/FLUX.png",
        "backgroundImage": "./assets/FLUX.png",
        "monochromeImage": "./assets/FLUX.png"
      },
      "package": "com.flux.app",
      "permissions": [
        "android.permission.RECEIVE_SMS",
        "android.permission.READ_SMS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0B0E14"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dee5db89-5d56-4941-bae9-260069b18c96"
      }
    }
  }
}